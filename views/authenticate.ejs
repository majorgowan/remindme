<!DOCTYPE html>
<html lang="en">

<%- include("partials/head.ejs") %>

<body>

<header>
    <%- include("partials/navbar.ejs") %>
</header>

<div class="main-container">

    <% if (locals.login) { %>
        <%- include("partials/loginform.ejs") %>
    <% } else if (locals.register) { %>
        <%- include("partials/registrationform.ejs") %>
    <% } else if (locals.confirmation) { %>
        <%- include("partials/confirmed.ejs") %>
    <% } else if (locals.resetpassword) { %>
        <%- include("partials/resetpasswordform.ejs") %>
    <% } %>

</div>

<%- include("partials/footer.ejs") %>

</body>
</html>